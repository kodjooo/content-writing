# API-ключ OpenAI для вызовов Assistants и генерации изображений
OPENAI_API_KEY=
# Опциональный API-ключ OpenAI только для генерации изображений
IMAGE_OPENAI_API_KEY=
# Необязательные идентификаторы организации/проекта OpenAI
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Идентификатор Google Sheets с данными по контенту
GOOGLE_SHEETS_SPREADSHEET_ID=
# Путь к файлу сервисного аккаунта Google (JSON)
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json
# Резервная переменная (в текущем runtime не используется)
GOOGLE_DRIVE_FOLDER_ID=


# Настройки обработки
PROCESSING_PER_RUN_ROWS=1
# Максимальное число итераций переписывания текста после комментария модератора
MODERATOR_MAX_ITERATIONS=5
# Резервное имя переменной для обратной совместимости
PROCESSING_MAX_REVISIONS=
PROCESSING_LOCK_TTL_MINUTES=15

# Конфигурация вкладок: JSON-массив с ассистентами писателя и модератора для каждой
# Пример: [{"tab":"VK","writer_model":"gpt-4.1","moderator_model":"gpt-4.1-mini","writer_system_prompt_path":"./prompts/vk/writer_system.txt","moderator_system_prompt_path":"./prompts/vk/moderator_system.txt","brief_system_prompt_path":"./prompts/vk/brief_system.txt","revision_user_template_path":"./prompts/vk/revision_user_template.txt","max_content_chars":3000,"writer_reasoning_effort":"low"}]
SHEETS_CONFIG=
# Список вкладок (через запятую), для которых не нужно генерировать изображения
IMAGE_DISABLED_TABS=
# Ассистент художественного брифа (единый для всех вкладок)
GLOBAL_IMAGE_BRIEF_MODEL=

# Каталог временных файлов приложения
TEMP_DIR=./tmp

# Глобальный флаг генерации изображений (true/false)
IMAGE_GENERATION_ENABLED=true
# Тестовый режим генерации (true/false): пропускает внешние API и возвращает тестовую ссылку
IMAGE_TEST_MODE=true
# Качество изображений: для gpt-image-1 — low/medium/high/auto, для dall-e-3 — standard/hd
IMAGE_QUALITY=high
# Размер изображений: для gpt-image-1 — 1024x1024/1024x1536/1536x1024/auto, для dall-e-3 — 1024x1024
IMAGE_SIZE=1536x1024
# Модель генерации изображений (например, gpt-image-1, dall-e-3)
IMAGE_MODEL=gpt-image-1
# API-ключ FreeImage.host (опционально)
FREEIMAGE_API_KEY=

# Планировщик запусков
SCHEDULE_ENABLED=false
RUN_ON_START=false
SCHEDULE_TIME=08:30
SCHEDULE_TIMEZONE=Europe/Moscow

# Уровень логирования приложения (DEBUG, INFO, WARNING...)
LOG_LEVEL=INFO
